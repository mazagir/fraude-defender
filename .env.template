# AegisShield local/deployment environment

# Required in all environments. Generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-a-64-char-random-secret

# development | testing | production
ENVIRONMENT=development

# Database Settings
# DB_PROVIDER defines the active database: direct (default) | sqlite | supabase | neon
DB_PROVIDER=direct
DATABASE_URL=sqlite:///./aegis_shield.db

# Dedicated connection strings (used if DB_PROVIDER is set to supabase or neon)
SUPABASE_DATABASE_URL=
NEON_DATABASE_URL=

# Required in production for B2B/API-key access. Comma-separated.
ALLOWED_API_KEYS=aegis_dev_api_key_2026

# Optional. If absent, the scanner uses deterministic local heuristics.
GEMINI_API_KEY=

# Optional frontend/backend origins. Comma-separated, no wildcard in production.
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://fraude-defender-1176.vercel.app
CORS_ALLOW_ORIGIN_REGEX=

# WebSocket telemetry auth
WS_AUTH_REQUIRED=true
